VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN refactored_design ;
DIEAREA ( 0 0 ) ( 100 100 ) ;
COMPONENTS 5 ;
- ALU U_ALU + PLACED ( 45 60 ) N ;
- RegisterFile U_REG + PLACED ( 30 50 ) N ;
- MemoryController U_MEM + PLACED ( 60 70 ) N ;
- Cache U_CAC + PLACED ( 40 50 ) N ;
- BusInterface U_BUS + PLACED ( 20 20 ) N ;
END COMPONENTS
END DESIGN
