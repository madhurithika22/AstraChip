VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN alu ;
DIEAREA ( 0 0 ) ( 100 100 ) ;
COMPONENTS 5 ;
- ALU U_ALU + PLACED ( 80 90 ) N ;
- RegisterFile U_RF + PLACED ( 30 50 ) N ;
- MemoryController U_MEM + PLACED ( 60 70 ) N ;
- Cache U_CACHE + PLACED ( 75 80 ) N ;
- BusInterface U_BUS + PLACED ( 20 20 ) N ;
END COMPONENTS
END DESIGN
